{
  "name": "thermostat-dark-card",
  "type": "module",
  "version": "1.0.0",
  "description": "A thermostat card with a round dial for Home Assistant — supports dark and light themes",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "automation",
    "lovelace",
    "custom-cards",
    "thermostat"
  ],
  "module": "thermostat-dark-card.js",
  "repository": "git@github.com:ciotlosm/lovelace-thermostat-dark-card.git",
  "author": "Marius Ciotlos <ciotlos@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "home-assistant-js-websocket": "^9.6.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "terser": "^5.37.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "preview": "vite preview --port 5000 --host 0.0.0.0",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "start:hass": "docker run --rm -p 8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:stable"
  }
}
