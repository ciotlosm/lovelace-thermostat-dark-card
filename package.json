{
  "name": "thermostat-dark-card",
  "type": "module",
  "version": "2.6.1",
  "description": "A thermostat card with a round dial for Home Assistant — supports dark and light themes",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "automation",
    "lovelace",
    "custom-cards",
    "thermostat"
  ],
  "module": "thermostat-dark-card.js",
  "repository": "git@github.com:ciotlosm/lovelace-thermostat-dark-card.git",
  "author": "Marius Ciotlos <ciotlos@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "home-assistant-js-websocket": "^9.6.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "terser": "^5.49.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && cp demo/index.html dist/demo.html",
    "preview": "vite preview --port 4000 --host 0.0.0.0",
    "check": "biome check",
    "check:fix": "biome check --write",
    "format": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start:hass": "podman run --rm -p 8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:stable"
  }
}
